{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
//  ↑ was "pipeline" in v1
    "dev": { "cache": false },
    "build": { 
      "dependsOn": ["^build"], 
      "outputs": ["dist/**", "build/**"] 
    },
    "test": { 
      "dependsOn": ["build"], 
      "outputs": [] 
    },
    "lint": { 
      "outputs": [] 
    }
  }
}